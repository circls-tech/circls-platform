{
  "permissions": {
    "deny": [
      "Bash(git push:* main)",
      "Bash(git push:* release)",
      "Bash(git push --force:*)",
      "Bash(gh pr merge:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/guard-git.sh" }
        ]
      }
    ]
  }
}
