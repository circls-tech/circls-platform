{
  "name": "@circls/api",
  "version": "0.0.0",
  "private": true,
  "description": "Circls platform Fastify API.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
