PORT=8080
LOG_LEVEL=info
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5433/circls

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Both must be set for real email to send. If either is missing the email
# channel runs in STUB mode (writes a notifications row + logs `email_stub`,
# but never delivers). See docs/EMAIL_SETUP.md for the signup + DNS runbook.
#   RESEND_API_KEY  — server key from https://resend.com/api-keys (starts re_…)
#   RESEND_FROM     — verified sender, e.g. "Circls <no-reply@circls.app>".
#                     The domain MUST be DNS-verified in the Resend dashboard.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Circls <no-reply@circls.app>

# ── Object storage (Cloudflare R2) — venue media ─────────────────────────────
# All four R2_* creds must be set for real uploads. If any is missing, storage
# runs in STUB mode (in-memory, per-process; uploads are not persisted).
# Create at: Cloudflare dash → R2 → Manage R2 API Tokens → Object Read & Write,
# scoped to the bucket. R2_ACCOUNT_ID is the hex prefix of the S3 endpoint.
# R2_PUBLIC_BASE_URL is the bucket's public r2.dev URL (or a custom domain) and
# is what venue-image URLs are built from. The bucket MUST be public.
# SECURITY: this is the PUBLIC venue-media bucket. Do NOT put KYC/private docs
# here — those get their own private bucket.
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_BUCKET=circls-media
# R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
